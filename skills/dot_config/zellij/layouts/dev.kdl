// Development Layout - nvim + lazygit + shell
// Location: ~/.config/zellij/layouts/dev.kdl
//
// Usage: zellij --layout dev --session project-name

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }
    
    tab name="Editor" focus=true {
        pane split_direction="vertical" {
            pane size="65%" command="nvim" {
                args "."
            }
            pane size="35%" split_direction="horizontal" {
                pane size="60%" command="lazygit"
                pane size="40%" // Shell for quick commands
            }
        }
    }
    
    tab name="Shell" {
        pane
    }
}
