{{- /* Fish Shell Configuration - Cross-Platform (Managed by chezmoi) */ -}}
{{- /* Platform: {{ .platform.id }} */ -}}
# Fish Shell Configuration
# Platform: {{ .platform.id }}
# Generated by chezmoi - DO NOT EDIT DIRECTLY

function fish_greeting
end

# ═══════════════════════════════════════════════════════════════════
# ENVIRONMENT FILE (secrets, API keys)
# ═══════════════════════════════════════════════════════════════════
if test -f ~/.config/fish/env.fish
    source ~/.config/fish/env.fish
end

# ═══════════════════════════════════════════════════════════════════
# HOMEBREW (Linux/macOS)
# ═══════════════════════════════════════════════════════════════════
{{- if not .platform.is_windows }}
if test -f /home/linuxbrew/.linuxbrew/bin/brew
    /home/linuxbrew/.linuxbrew/bin/brew shellenv | source
end
{{- if .platform.is_macos }}
if test -f /opt/homebrew/bin/brew
    /opt/homebrew/bin/brew shellenv | source
end
{{- end }}
{{- end }}

# ═══════════════════════════════════════════════════════════════════
# PATH
# ═══════════════════════════════════════════════════════════════════
{{- range .paths.add_paths }}
fish_add_path {{ . }}
{{- end }}
{{- if not .platform.is_windows }}
fish_add_path /snap/bin
fish_add_path {{ .chezmoi.homeDir }}/.claude/local/
{{- end }}

set -gx PNPM_HOME {{ .paths.pnpm_home | quote }}
if not string match -q -- $PNPM_HOME $PATH
    fish_add_path "$PNPM_HOME"
end

# ═══════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════
set -gx TERM {{ .shell.term | quote }}
set -gx EDITOR {{ .shell.editor | quote }}
set -gx VISUAL {{ .shell.editor | quote }}
set -gx FILE_MANAGER "yazi"
{{- if and .shell.gpg_tty (not .platform.is_windows) }}
set -gx GPG_TTY (tty)
{{- end }}

{{- if and .build.use_ccache (not .platform.is_windows) }}
set -gx CMAKE_C_COMPILER_LAUNCHER ccache
set -gx CMAKE_CXX_COMPILER_LAUNCHER ccache
{{- end }}
{{- if .build.cmake_parallel }}
{{- if .platform.is_windows }}
set -gx CMAKE_BUILD_PARALLEL_LEVEL (nproc 2>/dev/null; or echo 4)
{{- else }}
set -gx CMAKE_BUILD_PARALLEL_LEVEL (nproc)
{{- end }}
{{- end }}

# ═══════════════════════════════════════════════════════════════════
# INTERACTIVE SHELL SETUP
# ═══════════════════════════════════════════════════════════════════
if status is-interactive
    # Atuin (shell history)
    if command -v atuin >/dev/null
        atuin init fish | source
    end

    # Mise (runtime version manager)
    if command -v mise >/dev/null
        mise activate fish | source
    end
else
    # Non-interactive: use shims for mise
    if command -v mise >/dev/null
        mise activate fish --shims | source
    end
end

# ═══════════════════════════════════════════════════════════════════
# FZF
# ═══════════════════════════════════════════════════════════════════
set -gx FZF_DEFAULT_COMMAND 'rg --files --no-ignore-vcs --hidden'
set -gx FZF_DEFAULT_OPTS "\
--color=bg+:{{ .fzf.colors.bg_plus }},bg:{{ .fzf.colors.bg }},spinner:{{ .fzf.colors.spinner }},hl:{{ .fzf.colors.hl }} \
--color=fg:{{ .fzf.colors.fg }},header:{{ .fzf.colors.header }},info:{{ .fzf.colors.info }},pointer:{{ .fzf.colors.pointer }} \
--color=marker:{{ .fzf.colors.marker }},fg+:{{ .fzf.colors.fg_plus }},prompt:{{ .fzf.colors.prompt }},hl+:{{ .fzf.colors.hl_plus }} \
--color=selected-bg:{{ .fzf.colors.selected_bg }} \
--color=border:{{ .fzf.colors.border }},label:{{ .fzf.colors.label }}"
if command -v fzf >/dev/null
    fzf --fish | source
end

# ═══════════════════════════════════════════════════════════════════
# ZOXIDE (smart cd)
# ═══════════════════════════════════════════════════════════════════
if command -v zoxide >/dev/null
    zoxide init --cmd cd fish | source
end

# ═══════════════════════════════════════════════════════════════════
# SSH KEYS (login shell only)
# ═══════════════════════════════════════════════════════════════════
{{- if not .platform.is_windows }}
if status is-login
{{- range .ssh.keys }}
    if test -f ~/.ssh/{{ . }}
        ssh-add ~/.ssh/{{ . }} 2>/dev/null
    end
{{- end }}
end
{{- end }}

