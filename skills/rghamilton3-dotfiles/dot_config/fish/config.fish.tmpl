    abbr -a -- pki 'brew install'
    abbr -a -- pku 'brew update && brew upgrade'
    abbr -a -- pkr 'brew uninstall'
    abbr -a -- pks 'brew search'
else
    abbr -a -- pki 'sudo apt install'
    abbr -a -- pku 'sudo apt update && sudo apt upgrade'
    abbr -a -- pkr 'sudo apt remove'
    abbr -a -- pks 'apt search'
end
{{- else if .platform.is_macos }}
# macOS - Homebrew
abbr -a -- pki 'brew install'
abbr -a -- pku 'brew update && brew upgrade'
abbr -a -- pkr 'brew uninstall'
abbr -a -- pks 'brew search'
{{- else }}
# Generic fallback - apt
abbr -a -- pki 'sudo apt install'
abbr -a -- pku 'sudo apt update && sudo apt upgrade'
abbr -a -- pkr 'sudo apt remove'
abbr -a -- pks 'apt search'
{{- end }}

# ═══════════════════════════════════════════════════════════════════
# YAZI FILE MANAGER
# ═══════════════════════════════════════════════════════════════════
function y --wraps=yazi --description "Yazi with directory changing on exit"
    set tmp (mktemp -t "yazi-cwd.XXXXXX")
    yazi $argv --cwd-file="$tmp"
    if set cwd (command cat -- "$tmp"); and [ -n "$cwd" ]; and [ "$cwd" != "$PWD" ]
        builtin cd -- "$cwd"
    end
    rm -f -- "$tmp"
end

# ═══════════════════════════════════════════════════════════════════
# ZELLIJ HELPERS
# ═══════════════════════════════════════════════════════════════════
function zj --description "Attach or create zellij session"
    if set -q argv[1]
        zellij attach --create $argv[1]
    else
        zellij attach --create main
    end
end

function zjl --description "List zellij sessions"
    zellij list-sessions
end

function zjk --description "Kill zellij session"
    if set -q argv[1]
        zellij kill-session $argv[1]
    else
        echo "Usage: zjk <session-name>"
        zellij list-sessions
    end
end

function zproject --description "Start zellij session named after git repo or directory"
    if set -q ZELLIJ
        echo "Already in session: $ZELLIJ_SESSION_NAME"
        return 1
    end
    
    set -l git_root (git rev-parse --show-toplevel 2>/dev/null)
    set -l session_name (test -n "$git_root"; and basename $git_root; or basename (pwd))
    
    zellij attach --create $session_name
end

{{- if .remote.enabled }}

# ═══════════════════════════════════════════════════════════════════
# REMOTE DESKTOP HELPERS
# ═══════════════════════════════════════════════════════════════════
function desktop --description "SSH to desktop with Zellij"
    ssh {{ .remote.desktop_host }}
end

function desktop-code --description "SSH to desktop for Claude Code"
    ssh -t {{ .remote.desktop_host }} "cd ~/workspace && zellij attach --create code"
end
{{- end }}

# ═══════════════════════════════════════════════════════════════════
# ESP-IDF AUTO-SOURCE (Arch only)
# ═══════════════════════════════════════════════════════════════════
{{- if and .platform.is_arch (not .platform.is_wsl) }}
function __esp_idf_check --on-event fish_postexec
    status is-command-substitution; and return
    
    if test -f .esp-idf-project
        if not command -v idf.py &>/dev/null
            if test -f {{ .paths.esp_idf }}
                source {{ .paths.esp_idf }}
            end
        end
    end
end
{{- end }}

# ═══════════════════════════════════════════════════════════════════
# ROS2 JAZZY CONTAINER (distrobox)
# ═══════════════════════════════════════════════════════════════════
{{- if and .platform.is_linux (not .platform.is_wsl) }}
if set -q CONTAINER_ID; and test "$CONTAINER_ID" = "jazzy"
    # Use bass to source the bash setup scripts
    bass source /opt/ros/jazzy/setup.bash
    
    if test -f ~/ros2_ws/install/setup.bash
        bass source ~/ros2_ws/install/setup.bash
    end
    
    set -gx ROS_DOMAIN_ID 0
end
{{- end }}

# ═══════════════════════════════════════════════════════════════════
# WSL2-SPECIFIC
# ═══════════════════════════════════════════════════════════════════
{{- if .platform.is_wsl }}
# Windows interop
function winpath --description "Convert Unix path to Windows path"
    wslpath -w $argv
end

function unixpath --description "Convert Windows path to Unix path"
    wslpath -u $argv
end

# Open in Windows
function winopen --description "Open file/URL in Windows"
    cmd.exe /c start (wslpath -w $argv 2>/dev/null; or echo $argv)
end

# Clipboard helpers
function wcopy --description "Copy to Windows clipboard"
    clip.exe
end

function wpaste --description "Paste from Windows clipboard"
    powershell.exe -command Get-Clipboard
end
{{- end }}
