# Platform: {{ .platform.id }}

{{- if .api.github_token }}
set -gx GITHUB_TOKEN {{ .api.github_token | quote }}
{{- end }}

{{- if .api.openai_key }}
set -gx OPENAI_API_KEY {{ .api.openai_key | quote }}
{{- end }}

{{- if .api.anthropic_key }}
set -gx ANTHROPIC_API_KEY {{ .api.anthropic_key | quote }}
{{- end }}

{{- if .api.tivaly_key }}
set -gx TIVALY_API_KEY {{ .api.tivaly_key | quote }}
{{- end }}

{{- if .api.context7_key }}
set -gx UPSTASH_API_KEY {{ .api.context7_key | quote }}
{{- end }}

{{- if .api.gemini_key }}
set -gx GOOGLE_GEMINI_API_KEY {{ .api.gemini_key | quote }}
