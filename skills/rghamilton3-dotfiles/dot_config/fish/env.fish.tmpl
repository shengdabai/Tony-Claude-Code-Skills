{{- end }}

{{- if .api.opencode_gh_pat }}
set -gx OPENCODE_GH_PAT {{ .api.opencode_gh_pat | quote }}
{{- end }}

{{- if .database.postgres_url }}
set -gx DATABASE_URL {{ .database.postgres_url | quote }}
{{- end }}

{{- if .database.redis_url }}
set -gx REDIS_URL {{ .database.redis_url | quote }}
{{- end }}
