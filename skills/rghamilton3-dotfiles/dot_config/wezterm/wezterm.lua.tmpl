{{- /* WezTerm Configuration - Cross-Platform (Managed by chezmoi) */ -}}
{{- /* Supports: Windows, WSL2, Arch (KDE), Arch (Sway), macOS */ -}}
-- WezTerm Configuration
-- Platform: {{ .platform.id }}
-- Generated by chezmoi - DO NOT EDIT DIRECTLY

local wezterm = require("wezterm")
local config = wezterm.config_builder()

-- ═══════════════════════════════════════════════════════════════════
-- PLATFORM DETECTION (runtime, complements chezmoi detection)
-- ═══════════════════════════════════════════════════════════════════
local is_windows = wezterm.target_triple:find("windows") ~= nil
local is_linux = wezterm.target_triple:find("linux") ~= nil
local is_macos = wezterm.target_triple:find("darwin") ~= nil

-- ═══════════════════════════════════════════════════════════════════
-- DEFAULT SHELL / PROGRAM
-- ═══════════════════════════════════════════════════════════════════
{{- if .platform.is_windows }}
-- Windows: Launch into WSL2 Ubuntu with Zellij
config.default_prog = { "wsl.exe", "-d", "Ubuntu", "--", "zellij", "attach", "--create" }

-- Alternative: Just WSL without zellij auto-attach
-- config.default_prog = { "wsl.exe", "-d", "Ubuntu", "--", "fish", "-l" }

-- WSL domains for easy switching
config.wsl_domains = wezterm.default_wsl_domains()
{{- else if .platform.is_wsl }}
-- WSL2: Launch Zellij directly (we're already in WSL)
config.default_prog = { "zellij", "attach", "--create" }
{{- else if and .remote.enabled (eq .machine.role "laptop") }}
-- Thin-client laptop: Just launch shell, user will SSH to desktop
-- Use `ssh desktop` for remote Zellij, or `zj` for local session
config.default_prog = { "fish", "-l" }
{{- else }}
-- Desktop/Server: Launch Zellij directly
config.default_prog = { "zellij", "attach", "--create" }
{{- end }}

-- ═══════════════════════════════════════════════════════════════════
-- DISABLE WEZTERM MULTIPLEXING (Zellij handles this)
-- ═══════════════════════════════════════════════════════════════════
config.enable_tab_bar = false

-- ═══════════════════════════════════════════════════════════════════
-- FONTS
-- ═══════════════════════════════════════════════════════════════════
config.font = wezterm.font_with_fallback({
    "{{ .terminal.font_family }}",
    "Noto Sans Mono CJK KR",
    "Noto Sans CJK KR",
{{- if .platform.is_windows }}
    -- Windows fallbacks
    "Cascadia Code",
    "Consolas",
{{- end }}
})
config.font_size = {{ .terminal.font_size }}

-- ═══════════════════════════════════════════════════════════════════
-- COLORS
-- ═══════════════════════════════════════════════════════════════════
config.color_scheme = "Tokyo Night Storm"
config.colors = {
    selection_fg = "#c0caf5",
    selection_bg = "#33467c"  -- Visible blue highlight
}

-- ═══════════════════════════════════════════════════════════════════
-- WINDOW
-- ═══════════════════════════════════════════════════════════════════
{{- if .platform.is_windows }}
-- Windows: Keep title bar for dragging (no Alt+drag like Linux)
config.window_decorations = "TITLE | RESIZE"
{{- else if .platform.is_sway }}
-- Sway: Minimal decorations, use Mod+drag for moving
config.window_decorations = "RESIZE"
{{- else if .platform.is_kde }}
-- KDE: Minimal decorations, use Alt+drag or KWin rules
config.window_decorations = "RESIZE"
{{- else }}
-- Default: Minimal decorations
config.window_decorations = "RESIZE"
{{- end }}

config.window_padding = {
    left = 0,
    right = 0,
    top = 0,
    bottom = 0,
}

-- Scrollback (Zellij handles most, but this is fallback)
config.scrollback_lines = 10000

-- ═══════════════════════════════════════════════════════════════════
-- KEYBINDINGS
-- ═══════════════════════════════════════════════════════════════════
config.keys = {
    -- Disable WezTerm defaults that conflict with Zellij
    { key = "t", mods = "SUPER", action = wezterm.action.DisableDefaultAssignment },
    { key = "t", mods = "CTRL|SHIFT", action = wezterm.action.DisableDefaultAssignment },
    { key = "n", mods = "SUPER", action = wezterm.action.DisableDefaultAssignment },
    { key = "w", mods = "SUPER", action = wezterm.action.DisableDefaultAssignment },

    -- Claude Code integration (Shift+Enter sends ESC+Enter)
    {
        key = "Enter",
        mods = "SHIFT",
        action = wezterm.action.SendString("\x1b\r"),
    },

    -- Font size controls
    { key = "=", mods = "CTRL", action = wezterm.action.IncreaseFontSize },
    { key = "-", mods = "CTRL", action = wezterm.action.DecreaseFontSize },
    { key = "0", mods = "CTRL", action = wezterm.action.ResetFontSize },
}

{{- if and .platform.is_linux (not .platform.is_wsl) }}

-- Linux-specific: Distrobox container shortcuts
table.insert(config.keys, {
    key = "j",
    mods = "CTRL|SHIFT",
    action = wezterm.action.SpawnCommandInNewWindow({
        args = { "distrobox", "enter", "jazzy", "--", "fish" },
    }),
})
{{- end }}

{{- if or .platform.is_windows (eq .machine.role "laptop") }}

-- Quick SSH to desktop (for remote work)
table.insert(config.keys, {
    key = "d",
    mods = "CTRL|SHIFT",
    action = wezterm.action.SpawnCommandInNewWindow({
{{- if .platform.is_windows }}
        args = { "wsl.exe", "-d", "Ubuntu", "--", "ssh", "{{ .remote.desktop_host }}" },
{{- else }}
        args = { "ssh", "{{ .remote.desktop_host }}" },
{{- end }}
    }),
})
{{- end }}

-- ═══════════════════════════════════════════════════════════════════
-- SSH DOMAINS (for direct WezTerm SSH connections)
-- ═══════════════════════════════════════════════════════════════════
{{- if .remote.enabled }}
config.ssh_domains = {
    {
        name = "desktop-zellij",
        remote_address = "{{ .remote.desktop_ip }}",
        username = "{{ .remote.desktop_user }}",
        multiplexing = "None",  -- Let Zellij handle multiplexing
        assume_shell = "Posix",
        default_prog = { "zellij", "attach", "-c", "main" },
    },
}
{{- end }}

-- ═══════════════════════════════════════════════════════════════════
-- LAUNCH MENU
-- ═══════════════════════════════════════════════════════════════════
config.launch_menu = {
{{- if .platform.is_windows }}
    {
        label = "WSL2 Ubuntu (Zellij)",
        args = { "wsl.exe", "-d", "Ubuntu", "--", "zellij", "attach", "--create" },
    },
    {
        label = "WSL2 Ubuntu (Fish)",
        args = { "wsl.exe", "-d", "Ubuntu", "--", "fish", "-l" },
    },
    {
        label = "PowerShell",
        args = { "powershell.exe", "-NoLogo" },
    },
{{- end }}
{{- if .remote.enabled }}
    {
        label = "🖥️ Desktop (Zellij)",
{{- if .platform.is_windows }}
        args = { "wsl.exe", "-d", "Ubuntu", "--", "ssh", "{{ .remote.desktop_host }}" },
{{- else }}
        args = { "ssh", "{{ .remote.desktop_host }}" },
{{- end }}
    },
    {
        label = "🖥️ Desktop - Code Session",
{{- if .platform.is_windows }}
        args = { "wsl.exe", "-d", "Ubuntu", "--", "ssh", "{{ .remote.desktop_host }}-code" },
{{- else }}
        args = { "ssh", "{{ .remote.desktop_host }}-code" },
{{- end }}
    },
    {
        label = "🖥️ Desktop (raw SSH)",
{{- if .platform.is_windows }}
        args = { "wsl.exe", "-d", "Ubuntu", "--", "ssh", "{{ .remote.desktop_host }}-raw" },
{{- else }}
        args = { "ssh", "{{ .remote.desktop_host }}-raw" },
{{- end }}
    },
{{- end }}
{{- if and .remote.enabled (eq .machine.role "laptop") }}
    {
        label = "Local Zellij",
        args = { "zellij", "attach", "--create" },
    },
{{- else }}
    {
        label = "Zellij (new session)",
        args = { {{ if .platform.is_windows }}"wsl.exe", "-d", "Ubuntu", "--", {{ end }}"zellij" },
    },
{{- end }}
    {
        label = "Fish Shell",
        args = { {{ if .platform.is_windows }}"wsl.exe", "-d", "Ubuntu", "--", {{ end }}"fish", "-l" },
    },
}

-- ═══════════════════════════════════════════════════════════════════
-- MISC
-- ═══════════════════════════════════════════════════════════════════
config.automatically_reload_config = true
config.check_for_updates = false

return config
