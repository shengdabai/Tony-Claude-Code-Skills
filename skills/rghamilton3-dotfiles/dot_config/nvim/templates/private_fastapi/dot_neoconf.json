{
  "$schema": "https://raw.githubusercontent.com/folke/neoconf.nvim/main/schemas/neoconf.json",
  "lspconfig": {
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic",
            "autoSearchPaths": true,
            "useLibraryCodeForTypes": true,
            "diagnosticMode": "workspace"
          }
        }
      }
    }
  },
  "commands": {
    "FastAPIStart": {
      "description": "Start FastAPI development server",
      "command": "15split | terminal uvicorn main:app --reload --port 8000"
    },
    "FastAPITest": {
      "description": "Run FastAPI tests",
      "command": "15split | terminal pytest -v"
    }
  }
}
