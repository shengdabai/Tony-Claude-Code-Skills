@startuml IoT System Architecture

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

' Uncomment for different diagram levels:
' !include C4_Context.puml
' !include C4_Component.puml

title IoT System Container Diagram

' Define custom styles for IoT devices
AddElementTag("device", $bgColor="#8B9DC3", $borderColor="#29427A", $fontColor="#FFFFFF")
AddElementTag("embedded", $bgColor="#6B7A8F", $borderColor="#434A54", $fontColor="#FFFFFF")
AddElementTag("broker", $bgColor="#F7931E", $borderColor="#C5670D", $fontColor="#FFFFFF")
AddElementTag("service", $bgColor="#5BC0DE", $borderColor="#2E6DA4", $fontColor="#FFFFFF")
AddElementTag("external", $bgColor="#5CB85C", $borderColor="#398439", $fontColor="#FFFFFF")

' Define Persons
Person(user, "User", "End user interacting with the system")

' System Boundary
System_Boundary(iot_system, "IoT System") {

    ' Devices
    Container(presto, "Presto Display", "RP2350 + MicroPython", "Central display with touchscreen interface", $tags="device")
    Container(tembed, "T-Embed Timer", "ESP32-S3 + Arduino", "Desk timer with display", $tags="embedded")
    Container(streamdeck, "Stream Deck", "USB Device + Python", "Physical macro controller", $tags="embedded")

    ' Hub
    Container(jetson, "Jetson Nano", "Ubuntu Linux", "Central intelligence hub", $tags="device")

    ' Services on Hub
    Container(mqtt_broker, "MQTT Broker", "Mosquitto", "Message broker for pub/sub communication", $tags="broker")
    Container(api_gateway, "API Gateway", "FastAPI", "REST API for external integrations", $tags="service")
    Container(ai_service, "AI Service", "Python + TensorFlow", "ML inference for pattern analysis", $tags="service")
    ContainerDb(database, "Database", "PostgreSQL", "Persistent data storage", $tags="service")
    ContainerDb(cache, "Cache", "Redis", "In-memory cache", $tags="service")
}

' External Systems
System_Ext(android, "Android Phone", "Notification receiver", $tags="external")

' Relationships
Rel(user, presto, "Interacts with", "Touch")
Rel(user, tembed, "Views", "Visual")
Rel(user, streamdeck, "Controls", "Button press")

Rel(presto, mqtt_broker, "Publishes/Subscribes", "MQTT/WiFi")
Rel(tembed, mqtt_broker, "Publishes/Subscribes", "MQTT/WiFi")
Rel(streamdeck, api_gateway, "Sends commands", "WebSocket/USB")

Rel(mqtt_broker, ai_service, "Forwards events", "Internal")
Rel(api_gateway, mqtt_broker, "Publishes commands", "Internal")

Rel(ai_service, database, "Reads/Writes", "SQL")
Rel(ai_service, cache, "Caches", "Redis protocol")
Rel(api_gateway, database, "Queries", "SQL")

Rel(presto, android, "Sends notifications", "BLE")

' Notes
note right of mqtt_broker
  QoS 1 for important messages
  Retained messages for state
  Last Will Testament for presence
end note

note right of presto
  Primary UI
  BLE hub for phone
  Offline-first design
end note

@enduml

'==============================================================================
' SEQUENCE DIAGRAM TEMPLATE
'==============================================================================

@startuml Timer Start Sequence

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Sequence.puml

title Timer Start Sequence Diagram

participant "User" as user
participant "Presto\nDisplay" as presto
participant "MQTT\nBroker" as broker
participant "T-Embed\nTimer" as tembed
participant "AI\nService" as ai
participant "Android\nPhone" as phone

user -> presto: Tap "Start" button
activate presto

presto -> presto: Update local state
presto -> broker: PUBLISH\nargus/wrist/display/presto01/state\n{running: true, elapsed: 0}
activate broker

broker -> tembed: Forward state update
activate tembed
tembed -> tembed: Sync local state
tembed -> tembed: Update display
deactivate tembed

broker -> ai: Forward state update
activate ai
ai -> ai: Log event
ai -> ai: Analyze patterns
deactivate ai

presto -> phone: Send BLE notification\n"Timer started"
activate phone
phone -> phone: Display notification
deactivate phone

deactivate broker
deactivate presto

note over broker
  QoS 1 ensures delivery
  Retained flag stores last state
end note

@enduml

