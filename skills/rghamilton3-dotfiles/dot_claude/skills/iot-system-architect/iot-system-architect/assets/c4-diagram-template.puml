@startuml IoT System Deployment

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

title IoT System Deployment Diagram

Deployment_Node(living_room, "Living Room", "Physical Location") {
    Deployment_Node(presto_hw, "Presto Device", "RP2350 Hardware") {
        Container(presto_fw, "Firmware", "MicroPython", "Display and BLE hub")
    }
}

Deployment_Node(desk, "Desk Area", "Physical Location") {
    Deployment_Node(tembed_hw, "T-Embed Device", "ESP32-S3 Hardware") {
        Container(tembed_fw, "Firmware", "Arduino/ESP-IDF", "Timer display")
    }
}

Deployment_Node(hub_location, "Server Location", "Physical Location") {
    Deployment_Node(jetson_hw, "Jetson Nano", "ARM Linux Computer") {
        Deployment_Node(docker, "Docker", "Container Runtime") {
            Container(mosquitto, "Mosquitto", "MQTT Broker")
            Container(api, "FastAPI", "API Service")
            Container(ai, "AI Service", "ML Inference")
            Container(postgres, "PostgreSQL", "Database")
            Container(redis, "Redis", "Cache")
        }
    }

    Deployment_Node(streamdeck_hw, "Stream Deck Neo", "USB Device") {
        Container(streamdeck_app, "Python App", "Control interface")
    }
}

Deployment_Node(mobile, "Mobile Device", "Android Phone") {
    Container(android_app, "Flutter App", "Notification receiver")
}

' Network connections
Rel(presto_fw, mosquitto, "MQTT", "WiFi 2.4GHz")
Rel(tembed_fw, mosquitto, "MQTT", "WiFi 2.4GHz")
Rel(streamdeck_app, api, "WebSocket", "USB/Ethernet")
Rel(presto_fw, android_app, "Notifications", "BLE 5.0")

@enduml

'==============================================================================
' STATE DIAGRAM TEMPLATE
'==============================================================================

@startuml Timer State Machine

[*] --> Idle

Idle --> Working : start(work_duration)
Working --> Paused : pause()
Paused --> Working : resume()
Working --> Break : complete() [sessions < 4]
Working --> LongBreak : complete() [sessions >= 4]

Break --> Working : start(work_duration)
LongBreak --> Idle : complete()

Paused --> Idle : cancel()

state Working {
    [*] --> Counting
    Counting --> Notifying : elapsed >= duration
    Notifying --> [*]
}

state Break {
    [*] --> ShortBreak
    ShortBreak --> [*] : elapsed >= break_duration
}

state LongBreak {
    [*] --> ExtendedBreak
    ExtendedBreak --> [*] : elapsed >= long_break_duration
}

note right of Working
  Publishes state updates
  every second via MQTT
end note

note right of Break
  Sends notification
  when break starts
end note

@enduml

