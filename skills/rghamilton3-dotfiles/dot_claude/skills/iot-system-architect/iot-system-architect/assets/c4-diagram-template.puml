@startuml MQTT Broker Components

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title MQTT Broker Component Diagram

Container_Boundary(broker, "MQTT Broker") {
    Component(listener, "Connection Listener", "TCP/WebSocket", "Accepts client connections")
    Component(auth, "Authentication", "Plugin", "Validates credentials")
    Component(acl, "Authorization", "ACL", "Enforces topic permissions")
    Component(router, "Message Router", "Core", "Routes messages to subscribers")
    Component(persistence, "Persistence", "Database", "Stores QoS 1/2 messages")
    Component(retained, "Retained Messages", "In-Memory", "Stores retained messages")
    Component(lwt, "Last Will", "Manager", "Handles client disconnections")
}

Component(client_timer, "Timer Client", "MQTT Client", "ESP32 device")
Component(client_display, "Display Client", "MQTT Client", "RP2350 device")
ComponentDb(disk, "Disk Storage", "File System", "Persistent storage")

Rel(client_timer, listener, "Connect", "MQTT")
Rel(client_display, listener, "Connect", "MQTT")

Rel(listener, auth, "Authenticate")
Rel(listener, acl, "Authorize")
Rel(listener, router, "Register")

Rel(router, persistence, "Store QoS 1/2")
Rel(router, retained, "Store retained")
Rel(router, lwt, "Register LWT")

Rel(persistence, disk, "Write")
Rel(retained, disk, "Backup")

@enduml
